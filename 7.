class Empleado:
    def __init__(self, nombre, salario, departamento):
        self._nombre = nombre
        self._salario = salario
        self._departamento = departamento

    def aumentar_salario(self, porcentaje):
        if porcentaje > 0:
            self._salario += self._salario * (porcentaje / 100)

    def mostrar_informacion(self):
        print(f"Empleado: {self._nombre} | Dpto: {self._departamento} | Salario: ${self._salario}")

empleado1 = Empleado("Papanata", 50000, "Ventas")

empleado1.mostrar_informacion()
empleado1.aumentar_salario(10)
print("Aumento de salario.")
empleado1.mostrar_informacion()
